---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import NotesIndexView from '../components/notes/NotesIndexView.astro';
import { normalize } from '../lib/normalize';

const raw = await getCollection('notes');
const notes = raw
  .map((entry) => ({
    ...normalize(entry.id, entry.data),
  }))
  .sort((a, b) => b.date.localeCompare(a.date));

const categories = [...new Set(notes.map((n) => n.category))].sort();
---

<BaseLayout title="253eosam notes">
  <Header current="home" />
  <NotesIndexView notes={notes} categories={categories} />
</BaseLayout>

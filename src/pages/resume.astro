---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import ResumeView from '../components/resume/ResumeView.astro';
import resume from '../data/resume';
import { mapResumeData } from '../lib/resume-mapper';

const { profile, skills, experience, certifications, education, activities } = mapResumeData(resume);
---

<BaseLayout title="resume" description={`${profile.name} - ${profile.role}`}>
  <Header current="resume" />
  <ResumeView
    profile={profile}
    skills={skills}
    experience={experience}
    certifications={certifications}
    education={education}
    activities={activities}
  />
</BaseLayout>

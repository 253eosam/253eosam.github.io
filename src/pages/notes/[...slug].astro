---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import { normalize } from '../../lib/normalize';

export async function getStaticPaths() {
  const raw = await getCollection('notes');
  return raw.map((entry) => {
    const note = normalize(entry.id, entry.data);
    return {
      params: { slug: note.slug },
      props: { entry, note },
    };
  });
}

const { entry, note } = Astro.props;
const link = entry.data.external as string | undefined;
const { Content } = await render(entry);

function formatDate(dateStr: string): string {
  const [y, m, d] = dateStr.split('-');
  return `${y}년 ${parseInt(m)}월 ${parseInt(d)}일`;
}
---

<BaseLayout title={note.title} description={note.description}>
  <Header current="note" />
  <main class="container">
    <article class="note">
      <header class="note-header">
        <div class="note-meta">
          <span class="note-category">{note.category}</span>
          <time datetime={note.date}>{formatDate(note.date)}</time>
        </div>
        <h1 class="note-title">{note.title}</h1>
        {
          note.tags.length > 0 && (
            <div class="note-tags">
              {note.tags.map((tag) => (
                <span class="note-tag">{tag}</span>
              ))}
            </div>
          )
        }
      </header>
      {link ? (
        <div class="external-bookmark">
          <p>이 노트는 외부 사이트의 북마크입니다.</p>
          <a href={link} target="_blank" rel="noopener noreferrer" class="external-link-btn">
            외부 사이트로 이동 <span class="external-icon" aria-hidden="true" />
          </a>
        </div>
      ) : (
        <div class="prose">
          <Content />
        </div>
      )}
      <footer class="note-footer">
        <a href="/" class="back-link">&larr; 목록으로</a>
      </footer>
    </article>
  </main>
</BaseLayout>

<style>
  .note {
    padding: var(--space-2xl) 0 var(--space-3xl);
  }

  .note-header {
    margin-bottom: var(--space-2xl);
  }

  .note-meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.85rem;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-sm);
  }

  .note-category {
    font-weight: 600;
    color: var(--color-primary);
    text-transform: capitalize;
  }

  .note-title {
    font-size: 1.85rem;
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: -0.02em;
  }

  .note-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-top: var(--space-md);
  }

  .note-tag {
    font-size: 0.8rem;
    background: var(--color-tag-bg);
    color: var(--color-tag-text);
    padding: 3px 10px;
    border-radius: 9999px;
  }

  .note-footer {
    margin-top: var(--space-3xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
  }

  .back-link {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .back-link:hover {
    color: var(--color-primary);
  }

  .external-bookmark {
    text-align: center;
    padding: var(--space-3xl) 0;
  }

  .external-bookmark p {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-lg);
  }

  .external-link-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 20px;
    font-size: 0.95rem;
    font-weight: 600;
    color: #fff;
    background: var(--color-primary);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .external-link-btn:hover {
    opacity: 0.85;
    text-decoration: none;
  }

  .external-icon::after {
    content: "↗";
    display: inline-block;
    margin-left: 2px;
    font-size: 0.75em;
  }
</style>

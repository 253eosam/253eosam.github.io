---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import NoteDetailView from '../../components/notes/NoteDetailView.astro';
import { normalize } from '../../lib/normalize';

export async function getStaticPaths() {
  const raw = await getCollection('notes');
  return raw.map((entry) => {
    const note = normalize(entry.id, entry.data);
    return {
      params: { slug: note.slug },
      props: { entry, note },
    };
  });
}

const { entry, note } = Astro.props;
const link = entry.data.external as string | undefined;
const { Content, headings } = await render(entry);
const tocHeadings = headings.filter(
  (heading) =>
    (heading.depth === 2 || heading.depth === 3) && heading.text.trim() !== '목차'
);
const hasToc = tocHeadings.length > 0 && !link;
---

<BaseLayout title={note.title} description={note.description}>
  <Header current="note" />
  <NoteDetailView
    note={note}
    link={link}
    Content={Content}
    tocHeadings={tocHeadings}
    hasToc={hasToc}
  />
</BaseLayout>

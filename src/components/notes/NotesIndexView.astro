---
import CategoryFilter from '../CategoryFilter.astro';
import NoteCard from '../NoteCard.astro';

const { notes = [], categories = [] } = Astro.props;
---

<main class="container">
  <section class="hero">
    <h1 class="hero-title">Notes</h1>
    <p class="hero-desc">{notes.length}개의 노트</p>
  </section>
  <CategoryFilter categories={categories} />
  <section class="note-list">
    {
      notes.map((note) => (
        <NoteCard
          title={note.title}
          date={note.date}
          category={note.category}
          description={note.description}
          slug={note.slug}
          tags={note.tags}
          link={note.link}
        />
      ))
    }
  </section>
</main>

<style>
  .hero {
    padding: var(--space-2xl) 0 0;
  }

  .hero-title {
    font-size: 1.625rem;
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: var(--tracking-tight);
  }

  .hero-desc {
    margin-top: var(--space-xs);
    font-size: 0.9rem;
    color: var(--color-text-tertiary);
  }

  .note-list {
    padding-bottom: var(--space-3xl);
  }
</style>
